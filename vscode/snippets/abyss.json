{
  "Function": {
    "prefix": "func",
    "body": ["function ${1:name}() {", "    $0", "}"],
    "description": "Create a function"
  },
  "If Statement": {
    "prefix": "if",
    "body": ["if (${1:condition}) {", "    $0", "}"],
    "description": "If statement"
  },
  "For Loop": {
    "prefix": "for",
    "body": [
      "for (${1:init}; ${2:condition}; ${3:increment}) {",
      "    $0",
      "}"
    ],
    "description": "For loop"
  },
  "While Loop": {
    "prefix": "while",
    "body": ["while (${1:condition}) {", "    $0", "}"],
    "description": "While loop"
  },
  "Struct": {
    "prefix": "struct",
    "body": ["struct ${1:Name} {", "    $0", "}"],
    "description": "Define struct"
  },
  "Enum": {
    "prefix": "enum",
    "body": ["enum ${1:Name} {", "    ${2:VALUE1},", "    ${3:VALUE2}", "}"],
    "description": "Define an enum"
  },
  "Interface": {
    "prefix": "interface",
    "body": [
      "interface ${1:Name} {",
      "    function ${2:method_name}(${3:args}) : (${4:ret});",
      "}"
    ],
    "description": "Define an interface"
  }
}
